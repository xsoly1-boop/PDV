datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows"]
}

enum Giro {
  ABARROTES
  FARMACIA
  FERRETERIA
  REFACCIONARIA
  CAFETERIA
}

model ConfiguracionEmpresa {
  id            String   @id @default(uuid())
  nombreEmpresa String
  giro          Giro     @default(ABARROTES)
  rfc           String?
  logoUrl       String?
  formatoTicket Json?    // Configuración visual del ticket (secciones, fuentes, logos)
  creadoAt      DateTime @default(now())
  actualizadoAt DateTime @updatedAt
}



enum Rol {
  ADMINISTRADOR
  GERENTE
  CAJERO
  VENDEDOR_MOVIL
}

enum TipoMovimiento {
  ENTRADA_COMPRA
  ENTRADA_TRASPASO
  ENTRADA_DEVOLUCION
  ENTRADA_AJUSTE
  SALIDA_VENTA
  SALIDA_TRASPASO
  SALIDA_MERMA
  SALIDA_AJUSTE
}

enum EstadoReserva {
  ACTIVA
  COMPLETADA
  EXPIRADA
  CANCELADA
}

enum EstadoTraspaso {
  EN_TRANSITO
  COMPLETADO
  COMPLETADO_PARCIAL
  CANCELADO
}

model Usuario {
  id                 String              @id @default(uuid())
  nombre             String
  pin                String              // Hash para autorizaciones rápidas en caja
  rol                Rol
  activo             Boolean             @default(true)
  movimientos        KardexMovimiento[]
  ventas             Venta[]
  cotizaciones       Cotizacion[]
  traspasosEnviados  TraspasoMercancia[] @relation("UsuarioEnvia")
  traspasosRecibidos TraspasoMercancia[] @relation("UsuarioRecibe")
  turnos             TurnoCaja[]
  auditorias         BitacoraAuditoria[]
}

model Sucursal {
  id               String              @id @default(uuid())
  nombre           String
  direccion        String?
  balances         InventarioBalance[]
  movimientos      KardexMovimiento[]
  reservas         ReservaTemporal[]
  ventas           Venta[]
  cotizaciones     Cotizacion[]
  traspasosOrigen  TraspasoMercancia[] @relation("SucursalOrigen")
  traspasosDestino TraspasoMercancia[] @relation("SucursalDestino")
  lotes            LoteStock[]
}

model Producto {
  id                 String              @id @default(uuid())
  sku                String              @unique // Código interno único de catálogo
  nombre             String
  descripcion        String?
  costo              Decimal             @db.Decimal(10, 2)
  precio             Decimal             @db.Decimal(10, 2)
  permiteFracciones  Boolean             @default(false)
  categoriaId        String?
  proveedorId        String?
  metadatos          Json?
  
  categoria          Categoria?          @relation(fields: [categoriaId], references: [id])
  proveedor          Proveedor?          @relation(fields: [proveedorId], references: [id])
  codigos            CodigoBarras[]
  balances           InventarioBalance[]
  movimientos        KardexMovimiento[]
  reservas           ReservaTemporal[]
  detallesVenta      DetalleVenta[]
  detallesCotizacion DetalleCotizacion[]
  detallesTraspaso   DetalleTraspaso[]
  lotes              LoteStock[]
}

model CodigoBarras {
  id         String   @id @default(uuid())
  codigo     String   @unique // Código escaneable (EAN, UPC, código de proveedor)
  productoId String
  producto   Producto @relation(fields: [productoId], references: [id], onDelete: Cascade)
}

// Tabla de agregación para consultas rápidas de stock por sucursal
model InventarioBalance {
  id         String   @id @default(uuid())
  sucursalId String
  productoId String
  stockReal  Decimal  @default(0) @db.Decimal(10, 3) // Stock físico en tienda
  reservado  Decimal  @default(0) @db.Decimal(10, 3) // Stock comprometido en cotizaciones móviles
  sucursal   Sucursal @relation(fields: [sucursalId], references: [id])
  producto   Producto @relation(fields: [productoId], references: [id])

  @@unique([sucursalId, productoId])
}

// El Kardex: Registro inmutable de transacciones de inventario
model KardexMovimiento {
  id          String         @id @default(uuid())
  sucursalId  String
  productoId  String
  usuarioId   String
  tipo        TipoMovimiento
  cantidad    Decimal        @db.Decimal(10, 3) // Valores siempre positivos. El tipo determina si suma o resta.
  referencia  String?        // ID del ticket de venta, ID de orden de compra, etc.
  observacion String?
  creadoAt    DateTime       @default(now())
  
  sucursal    Sucursal       @relation(fields: [sucursalId], references: [id])
  producto    Producto       @relation(fields: [productoId], references: [id])
  usuario     Usuario        @relation(fields: [usuarioId], references: [id])

  @@index([sucursalId, productoId])
  @@index([creadoAt])
}

// Reservas temporales generadas desde la app Android
model ReservaTemporal {
  id           String        @id @default(uuid())
  sucursalId   String
  productoId   String
  cantidad     Decimal       @db.Decimal(10, 3)
  estado       EstadoReserva @default(ACTIVA)
  expiraAt     DateTime
  creadoAt     DateTime      @default(now())
  
  sucursal     Sucursal      @relation(fields: [sucursalId], references: [id])
  producto     Producto      @relation(fields: [productoId], references: [id])
  cotizacionId String?
  cotizacion   Cotizacion?   @relation(fields: [cotizacionId], references: [id], onDelete: Cascade)

  @@index([expiraAt, estado])
}

// Ventas / Tickets de cobro
model Venta {
  id              String         @id @default(uuid())
  folio           String         @unique
  sucursalId      String
  usuarioId       String
  clienteId       String?
  total           Decimal        @db.Decimal(10, 2)
  subtotal        Decimal        @db.Decimal(10, 2)
  descuento       Decimal        @db.Decimal(10, 2) @default(0)
  esOffline       Boolean        @default(false)
  offlineCreadoAt DateTime?
  creadoAt        DateTime       @default(now())
  
  sucursal        Sucursal       @relation(fields: [sucursalId], references: [id])
  usuario         Usuario        @relation(fields: [usuarioId], references: [id])
  cliente         Cliente?       @relation(fields: [clienteId], references: [id])
  detalles        DetalleVenta[]
  factura         FacturaCFDI?
}

model DetalleVenta {
  id             String   @id @default(uuid())
  ventaId        String
  productoId     String
  cantidad       Decimal  @db.Decimal(10, 3)
  precioUnitario Decimal  @db.Decimal(10, 2)
  subtotal       Decimal  @db.Decimal(10, 2)
  
  venta          Venta    @relation(fields: [ventaId], references: [id], onDelete: Cascade)
  producto       Producto @relation(fields: [productoId], references: [id])
}

// Cotizaciones / Pedidos móviles de vendedores en piso
model Cotizacion {
  id            String            @id @default(uuid())
  folio         String            @unique
  codigoCorto   String            // 4 dígitos para jalar en caja rápida
  sucursalId    String
  usuarioId     String
  clienteNombre String?
  clienteId     String?
  total         Decimal           @db.Decimal(10, 2)
  subtotal      Decimal           @db.Decimal(10, 2)
  estado        EstadoReserva     @default(ACTIVA)
  expiraAt      DateTime
  creadoAt      DateTime          @default(now())
  
  sucursal      Sucursal          @relation(fields: [sucursalId], references: [id])
  cliente       Cliente?          @relation(fields: [clienteId], references: [id])
  usuario       Usuario           @relation(fields: [usuarioId], references: [id])
  detalles      DetalleCotizacion[]
  reservas      ReservaTemporal[]

  @@index([codigoCorto, estado])
}

model DetalleCotizacion {
  id             String     @id @default(uuid())
  cotizacionId   String
  productoId     String
  cantidad       Decimal    @db.Decimal(10, 3)
  precioUnitario Decimal    @db.Decimal(10, 2)
  subtotal       Decimal    @db.Decimal(10, 2)
  
  cotizacion     Cotizacion @relation(fields: [cotizacionId], references: [id], onDelete: Cascade)
  producto       Producto   @relation(fields: [productoId], references: [id])
}

// Traspasos de mercancía entre sucursales
model TraspasoMercancia {
  id                String            @id @default(uuid())
  origenSucursalId  String
  destinoSucursalId String
  usuarioEnviaId    String
  usuarioRecibeId   String?
  estado            EstadoTraspaso    @default(EN_TRANSITO)
  creadoAt          DateTime          @default(now())
  recibidoAt        DateTime?
  
  origen            Sucursal          @relation("SucursalOrigen", fields: [origenSucursalId], references: [id])
  destino           Sucursal          @relation("SucursalDestino", fields: [destinoSucursalId], references: [id])
  usuarioEnvia      Usuario           @relation("UsuarioEnvia", fields: [usuarioEnviaId], references: [id])
  usuarioRecibe     Usuario?          @relation("UsuarioRecibe", fields: [usuarioRecibeId], references: [id])
  detalles          DetalleTraspaso[]
}

model DetalleTraspaso {
  id               String            @id @default(uuid())
  traspasoId       String
  productoId       String
  cantidadEnviada  Decimal           @db.Decimal(10, 3)
  cantidadRecibida Decimal?          @db.Decimal(10, 3)
  
  traspaso         TraspasoMercancia @relation(fields: [traspasoId], references: [id], onDelete: Cascade)
  producto         Producto          @relation(fields: [productoId], references: [id])
}

enum EstadoCFDI {
  PENDIENTE
  TIMBRADA
  CANCELADA
  FALLIDA
}

model FacturaCFDI {
  id           String     @id @default(uuid())
  ventaId      String     @unique
  venta        Venta      @relation(fields: [ventaId], references: [id], onDelete: Cascade)
  uuidSat      String?    @unique // UUID retornado por el PAC
  rfcReceptor  String
  razonSocial  String
  usoCFDI      String
  xmlUrl       String?
  pdfUrl       String?
  estado       EstadoCFDI @default(PENDIENTE)
  errorPac     String?
  timbradaAt   DateTime?
  creadoAt     DateTime   @default(now())
}

model Cliente {
  id              String               @id @default(uuid())
  nombre          String
  telefono        String?
  email           String?
  direccion       String?
  limiteCredito   Decimal              @db.Decimal(10, 2) @default(0)
  saldoDeudor     Decimal              @db.Decimal(10, 2) @default(0)
  rfc             String?
  razonSocial     String?
  regimenFiscal   String?
  codigoPostal    String?
  direccionFiscal String?
  activo          Boolean              @default(true)
  creadoAt        DateTime             @default(now())
  
  ventas          Venta[]
  cotizaciones    Cotizacion[]
  transacciones   CreditoTransaccion[]
}

enum TipoCredito {
  CARGO
  ABONO
}

model CreditoTransaccion {
  id          String       @id @default(uuid())
  clienteId   String
  cliente     Cliente      @relation(fields: [clienteId], references: [id])
  tipo        TipoCredito
  monto       Decimal      @db.Decimal(10, 2)
  concepto    String
  ventaId     String?
  creadoAt    DateTime     @default(now())

  @@index([clienteId])
  @@index([creadoAt])
}

model Proveedor {
  id            String         @id @default(uuid())
  nombre        String
  representante String?
  telefonos     String?
  correos       String?
  paginaWeb     String?
  notas         String?
  creadoAt      DateTime       @default(now())
  
  productos     Producto[]
  gastos        GastoGeneral[]
}

model GastoGeneral {
  id           String      @id @default(uuid())
  descripcion  String
  monto        Decimal     @db.Decimal(10, 2)
  categoria    String
  fecha        DateTime    @default(now())
  proveedorId  String?
  proveedor    Proveedor?  @relation(fields: [proveedorId], references: [id], onDelete: SetNull)
  creadoAt     DateTime    @default(now())

  @@index([fecha])
  @@index([proveedorId])
}

model Categoria {
  id        String     @id @default(uuid())
  nombre    String     @unique
  creadoAt  DateTime   @default(now())
  
  productos Producto[]
}

enum EstadoTurno {
  ABIERTO
  CERRADO
}

model TurnoCaja {
  id              String           @id @default(uuid())
  usuarioId       String
  usuario         Usuario          @relation(fields: [usuarioId], references: [id])
  fondoInicial    Decimal          @db.Decimal(10, 2)
  efectivoCierre  Decimal?         @db.Decimal(10, 2)
  estado          EstadoTurno      @default(ABIERTO)
  observaciones   String?
  abiertoAt       DateTime         @default(now())
  cerradoAt       DateTime?
  flujos          FlujoEfectivo[]
}

enum TipoFlujo {
  INGRESO
  EGRESO
}

model FlujoEfectivo {
  id          String    @id @default(uuid())
  turnoId     String
  turno       TurnoCaja @relation(fields: [turnoId], references: [id], onDelete: Cascade)
  tipo        TipoFlujo
  monto       Decimal   @db.Decimal(10, 2)
  motivo      String
  creadoAt    DateTime  @default(now())
}

model BitacoraAuditoria {
  id          String   @id @default(uuid())
  usuarioId   String
  usuario     Usuario  @relation(fields: [usuarioId], references: [id])
  accion      String   // E.g., "CANCELACION_TICKET", "AJUSTE_INVENTARIO", "EDICION_PRECIO"
  tabla       String?  // Nombre de la tabla afectada
  registroId  String?  // ID del registro
  detalles    String   // JSON o cadena descriptiva del cambio realizado
  creadoAt    DateTime @default(now())

  @@index([creadoAt])
  @@index([usuarioId])
}

model LoteStock {
  id             String    @id @default(uuid())
  lote           String
  productoId     String
  sucursalId     String
  stock          Decimal   @default(0) @db.Decimal(10, 3)
  fechaCaducidad DateTime?
  producto       Producto  @relation(fields: [productoId], references: [id], onDelete: Cascade)
  sucursal       Sucursal  @relation(fields: [sucursalId], references: [id], onDelete: Cascade)
  creadoAt       DateTime  @default(now())

  @@unique([sucursalId, productoId, lote])
}
