{
  "name": "eleventa-converter-gui",
  "version": "1.0.0",
  "description": "GUI tool to convert Firebird .fdb to Apex JSON",
  "main": "main.js",
  "scripts": {
    "dev": "vite",
    "electron": "electron .",
    "start": "npm run dev & npm run electron",
    "build": "vite build && electron-builder",
    "postinstall": "npm run build"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.0.0",
    "concurrently": "^8.2.0",
    "electron": "30.0.0",
    "electron-builder": "^24.6.0",
    "vite": "^5.2.0"
  },
  "build": {
    "appId": "com.eleventa.converter",
    "mac": {
      "target": "dmg",
      "category": "public.app-category.utilities"
    },
    "electronVersion": "30.0.0",
    "asarUnpack": [
      "scripts/*"
    ]
  }
}
